# ========================================
# AstralLounge 环境变量配置
# ========================================
# 复制此文件为 .env 并修改对应值

# ===== 应用设置 =====
APP_NAME=AstralLounge
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===== 前端路径（可选）==========
# 如果设置了 FRONTEND_PATH，后端服务会直接托管前端静态文件
# 示例: FRONTEND_PATH=./frontend/dist
FRONTEND_PATH=

# ===== CORS 跨域配置 =====
# 允许的前端地址，逗号分隔
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== Ollama 配置 =====
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL_NAME=llama3.2

# ===== Redis 缓存（可选）=====
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== OpenAI API（可选）=====
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Claude API（可选）=====
CLAUDE_API_KEY=

# ===== Azure OpenAI（可选）=====
AZURE_API_KEY=
AZURE_ENDPOINT=

# ===== OpenRouter（可选）=====
OPENROUTER_API_KEY=

# ===== 搜索引擎 API Keys（可选）=====
GOOGLE_API_KEY=
BING_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPER_API_KEY=

# ===== SearXNG 自建搜索（可选）=====
SEARXNG_URL=http://localhost:8888

# ===== 向量数据库配置 =====
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./data/vector_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===== 数据目录 =====
DATA_DIR=./data
CHARACTERS_DIR=./data/characters
WORLD_INFO_DIR=./data/world_info
MODELS_DIR=./models

# ===== Token 限制 =====
MAX_TOKEN_LIMIT=4096
DEFAULT_MAX_TOKENS=512
DEFAULT_TEMPERATURE=0.7
SESSION_TTL=86400

# ===== 记忆功能 =====
MEMORY_ENABLED=true
